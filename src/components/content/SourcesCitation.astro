---
interface Props {
  sources: string[];
}

const { sources } = Astro.props;
---

{sources.length > 0 && (
  <section class="sources" aria-label="Referencias y fuentes">
    <h3>Referencias</h3>
    <ol>
      {sources.map(source => <li>{source}</li>)}
    </ol>
  </section>
)}

<style>
  .sources {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-border);
  }
  .sources h3 {
    font-size: 1.125rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  .sources ol {
    padding-left: 1.25rem;
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.8;
  }
  .sources li { margin-bottom: 0.5rem; }
</style>
