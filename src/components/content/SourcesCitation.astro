---
interface Props {
  sources: string[];
}

const { sources } = Astro.props;
---

{sources.length > 0 && (
  <section class="sources" aria-label="Referencias y fuentes">
    <h3>Referencias</h3>
    <ol>
      {sources.map(source => <li>{source}</li>)}
    </ol>
  </section>
)}

<style>
  .sources {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 0.5px solid var(--line);
  }
  .sources h3 {
    font-family: var(--font-serif);
    font-size: 22px;
    margin-bottom: 1rem;
    color: var(--ink-1);
  }
  .sources ol {
    padding-left: 1.25rem;
    font-size: 13.5px;
    color: var(--ink-2);
    line-height: 1.7;
  }
  .sources li {
    margin-bottom: 0.5rem;
    word-break: break-word;
  }
</style>
