---
import { formatDate } from '../../utils/dates';
import { getCategoryBadgeClass } from '../../utils/categories';
import type { Category } from '../../utils/categories';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: Category;
  slug: string;
  image?: string;
  readingTime?: number;
}

const { title, description, pubDate, category, slug, image, readingTime } = Astro.props;
---

<article class="card article-card">
  <a href={`/blog/${slug}`} class="article-card__link">
    <div class="article-card__image">
      {image
        ? <img src={image} alt={title} loading="lazy" decoding="async" />
        : <div class="article-card__placeholder" />
      }
    </div>
    <div class="article-card__body">
      <span class={getCategoryBadgeClass(category)}>{category}</span>
      <h3 class="article-card__title">{title}</h3>
      <p class="article-card__excerpt">{description}</p>
      <div class="article-card__meta">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time>
        {readingTime && <span>{readingTime} min lectura</span>}
      </div>
    </div>
  </a>
</article>

<style>
  .article-card__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }
  .article-card__image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--color-border);
  }
  .article-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .card:hover .article-card__image img { transform: scale(1.05); }
  .article-card__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    opacity: 0.15;
  }
  .article-card__body { padding: 1.25rem; }
  .article-card__title {
    font-size: 1.125rem;
    margin: 0.75rem 0 0.5rem;
    line-height: 1.4;
  }
  .article-card__excerpt {
    font-size: 0.875rem;
    color: var(--color-text-light);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-card__meta {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
</style>
