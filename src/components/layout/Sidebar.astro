---
import { getCollection } from 'astro:content';
import AdSenseSlot from '../monetization/AdSenseSlot.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const popular = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<aside class="sidebar" aria-label="Barra lateral">
  <div class="sidebar__section">
    <h4 class="sidebar__title">Mas leidos</h4>
    <ul class="sidebar__list">
      {popular.map((post, i) => (
        <li class="sidebar__item">
          <span class="sidebar__num">{String(i + 1).padStart(2, '0')}</span>
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
        </li>
      ))}
    </ul>
  </div>

  <AdSenseSlot position="sidebar" />

  <div class="sidebar__section sidebar__yt">
    <h4 class="sidebar__title">YouTube</h4>
    <p class="sidebar__yt-text">Tips de salud en 60 segundos. Shorts diarios con datos reales.</p>
    <a href="https://www.youtube.com/@VidaaSana360" target="_blank" rel="noopener" class="btn btn--primary btn--full">
      Ver canal &rarr;
    </a>
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .sidebar__section {
    background: var(--surface-1);
    border: 0.5px solid var(--line);
    border-radius: var(--radius);
    padding: 1.5rem;
    backdrop-filter: blur(14px) saturate(120%);
    -webkit-backdrop-filter: blur(14px) saturate(120%);
  }
  .sidebar__title {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-1);
    margin-bottom: 14px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--accent);
  }
  .sidebar__list { list-style: none; padding: 0; margin: 0; }
  .sidebar__item {
    display: flex;
    gap: 0.75rem;
    padding: 12px 0;
    border-bottom: 0.5px solid var(--line);
    align-items: baseline;
  }
  .sidebar__item:last-child { border-bottom: none; }
  .sidebar__num {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 22px;
    color: var(--accent);
    opacity: 0.6;
    flex-shrink: 0;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .sidebar__item a {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-1);
    line-height: 1.35;
    text-decoration: none;
  }
  .sidebar__item a:hover { color: var(--accent); }
  .sidebar__yt {
    background: linear-gradient(135deg,
      color-mix(in oklab, var(--accent) 18%, var(--surface-1)),
      var(--surface-1));
    border: 0.5px solid color-mix(in oklab, var(--accent) 40%, var(--line));
  }
  .sidebar__yt-text {
    font-size: 14px;
    color: var(--ink-2);
    margin-bottom: 14px;
    line-height: 1.5;
  }
  .btn--full { width: 100%; justify-content: center; }
</style>
