---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const allItems = [{ label: 'Inicio', href: '/' }, ...items];
---

<nav class="breadcrumbs" aria-label="Ruta de navegacion">
  <ol>
    {allItems.map((item, i) => (
      <li>
        {item.href && i < allItems.length - 1
          ? <a href={item.href}>{item.label}</a>
          : <span aria-current={i === allItems.length - 1 ? 'page' : undefined}>{item.label}</span>
        }
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs { margin-bottom: 1.5rem; }
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    list-style: none;
    font-size: 12px;
    color: var(--ink-3);
    gap: 0.25rem;
    letter-spacing: 0.04em;
  }
  .breadcrumbs li:not(:last-child)::after {
    content: '/';
    margin-left: 0.4rem;
    color: var(--line-strong);
  }
  .breadcrumbs a { color: var(--ink-2); transition: color 0.15s; }
  .breadcrumbs a:hover { color: var(--accent); }
  .breadcrumbs [aria-current] { color: var(--ink-1); font-weight: 500; }
</style>
