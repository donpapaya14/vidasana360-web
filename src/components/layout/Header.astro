---
const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/blog', label: 'Articulos' },
  { href: '/categoria/nutrition', label: 'Nutricion' },
  { href: '/categoria/fitness', label: 'Ejercicio' },
  { href: '/categoria/mental-health', label: 'Mente' },
  { href: '/categoria/wellness', label: 'Longevidad' },
  { href: '/categoria/nutrition', label: 'Recetas' },
  { href: '/sobre-nosotros', label: 'Sobre' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="topbar">
  <div class="container topbar__inner">
    <a href="/" class="topbar__brand" aria-label="VidaSana360 — Inicio">
      <span class="brand-mark" aria-hidden="true">VS</span>
      <span class="brand-name">Vida<em>Sana</em><strong>360</strong></span>
    </a>

    <nav class="topnav-links" aria-label="Navegacion principal">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['topnav-link', { active: isActive(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button class="topbar__menu-btn" aria-label="Abrir menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    background: color-mix(in oklab, var(--bg) 78%, transparent);
    border-bottom: 0.5px solid var(--line);
  }
  .topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    gap: 18px;
  }
  .topbar__brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--ink-1);
    flex-shrink: 0;
  }
  .topbar__brand:hover .brand-name em { color: var(--accent-secondary); }

  .topnav-links {
    display: flex;
    gap: 22px;
    font-size: 13px;
    color: var(--ink-2);
  }
  .topnav-link {
    cursor: pointer;
    text-decoration: none;
    color: var(--ink-2);
    transition: color 0.15s;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 6px 2px;
  }
  .topnav-link:hover { color: var(--ink-1); }
  .topnav-link.active {
    color: var(--ink-1);
    font-weight: 600;
    border-bottom: 1px solid var(--accent);
  }

  .topbar__menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .topbar__menu-btn span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--ink-1);
    border-radius: 2px;
    transition: 0.3s;
  }

  @media (max-width: 900px) {
    .topnav-links { display: none; }
    .topbar__menu-btn { display: flex; }
    .topnav-links.mobile-open {
      display: flex;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: color-mix(in oklab, var(--bg) 92%, transparent);
      backdrop-filter: blur(16px);
      padding: 18px 28px;
      border-bottom: 0.5px solid var(--line);
      gap: 14px;
    }
  }
</style>

<script>
  const btn = document.querySelector('.topbar__menu-btn');
  const nav = document.querySelector('.topnav-links');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('mobile-open');
  });
</script>
