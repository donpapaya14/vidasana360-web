---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CookieConsent from '../components/monetization/CookieConsent.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Salud, bienestar y nutricion basados en ciencia. Consejos practicos respaldados por estudios reales.',
  ogImage = '/og-default.jpg',
  ogType = 'website',
  canonicalUrl,
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const fullTitle = title === 'VidaSana360' ? title : `${title} | VidaSana360`;
const resolvedOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const resolvedCanonical = canonicalUrl ?? Astro.url.href;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={resolvedCanonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={resolvedOgImage} />
  <meta property="og:url" content={resolvedCanonical} />
  <meta property="og:locale" content="es_ES" />
  <meta property="og:site_name" content="VidaSana360" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={resolvedOgImage} />

  <!-- Fonts: Fraunces (display serif) + Inter (sans) + Pacifico (script accent) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..600&family=Inter:wght@300;400;500;600;700&family=Pacifico&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Theme color (matches deep green bg) -->
  <meta name="theme-color" content="#0d1f17" />

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="VidaSana360" href="/rss.xml" />

  <!-- Schema.org WebSite -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "VidaSana360",
    "url": "https://vida-sana-360.com",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://vida-sana-360.com/blog?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
</head>
<body>
  <!-- Decorative full-page background (healthy meal hero) -->
  <div class="site-bg" aria-hidden="true">
    <img
      src="https://images.pexels.com/photos/1640774/pexels-photo-1640774.jpeg?auto=compress&cs=tinysrgb&w=1920&q=70"
      alt=""
      loading="eager"
      decoding="async"
    />
    <div class="site-bg-mask"></div>
  </div>

  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <CookieConsent />
</body>
</html>
