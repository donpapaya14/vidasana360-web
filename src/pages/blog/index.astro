---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/content/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Todos los articulos" description="Articulos de salud, nutricion, ejercicio y bienestar basados en evidencia cientifica.">
  <section class="section">
    <div class="container">
      <div class="eyebrow">Biblioteca</div>
      <h1 class="section-title" style="margin-bottom:6px">Todos los artículos</h1>
      <p class="page-subtitle">Salud y bienestar respaldados por ciencia real</p>
      <div class="articles-grid">
        {sortedPosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            image={post.data.image}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
