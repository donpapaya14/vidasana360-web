---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/content/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, getCategoryName } from '../../utils/categories';
import type { Category } from '../../utils/categories';

export function getStaticPaths() {
  return Object.keys(CATEGORIES).map(cat => ({
    params: { category: cat },
  }));
}

const { category } = Astro.params as { category: Category };
const catInfo = CATEGORIES[category];

const posts = await getCollection('blog', ({ data }) => !data.draft && data.category === category);
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title={catInfo.name}
  description={`Articulos de ${catInfo.name.toLowerCase()}: ${catInfo.description.toLowerCase()}.`}
>
  <section class="section">
    <div class="container">
      <div class="eyebrow">Categoría</div>
      <h1 class="section-title" style="margin-bottom:6px">{catInfo.name}</h1>
      <p class="page-subtitle">{catInfo.description}</p>
      {sorted.length > 0 ? (
        <div class="articles-grid">
          {sorted.map(post => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              slug={post.id}
              image={post.data.image}
              readingTime={post.data.readingTime}
            />
          ))}
        </div>
      ) : (
        <p class="empty">Próximamente artículos en esta categoría.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .empty { color: var(--ink-3); font-style: italic; }
</style>
