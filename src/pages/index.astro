---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/content/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../utils/categories';
import type { Category } from '../utils/categories';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const categories = Object.entries(CATEGORIES) as [Category, (typeof CATEGORIES)[Category]][];
---

<BaseLayout title="VidaSana360" description="Salud, nutricion y perdida de grasa basados en ciencia. Consejos practicos respaldados por estudios reales — sin mitos ni productos milagro.">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero__inner hero-grid">
      <div class="hero-text">
        <div class="eyebrow">Guía editorial de salud y fitness</div>
        <h1 class="display hero__title">
          Salud,<br />
          <em>basada en ciencia</em>
        </h1>
        <p class="lede hero__subtitle">
          Nutrición, ejercicio y pérdida de grasa con estudios reales.
          Sin mitos, sin productos milagro — solo lo que de verdad funciona.
        </p>
        <div class="hero__actions">
          <a href="/blog" class="btn-primary">Leer artículos &rarr;</a>
          <a href="#categories" class="btn-ghost">Explorar categorías</a>
        </div>

        <div class="pop-chips" aria-label="Temas populares">
          <span class="pop-chips-label">Popular</span>
          <a href="/categoria/nutrition" class="pop-chip">Ayuno intermitente</a>
          <a href="/categoria/fitness" class="pop-chip">Pérdida de grasa</a>
          <a href="/categoria/mental-health" class="pop-chip">Sueño profundo</a>
          <a href="/categoria/wellness" class="pop-chip">Longevidad</a>
          <a href="/categoria/nutrition" class="pop-chip">Recetas saludables</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Articles -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <div>
          <div class="eyebrow">Reciente</div>
          <h2 class="section-title">Últimos artículos</h2>
        </div>
        <a href="/blog" class="section__link">Ver todos &rarr;</a>
      </div>
      <div class="articles-grid">
        {latestPosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            slug={post.id}
            image={post.data.image}
            readingTime={post.data.readingTime}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section id="categories" class="section section--alt">
    <div class="container">
      <div style="text-align:center;margin-bottom:36px">
        <div class="eyebrow" style="justify-content:center">Explora</div>
        <h2 class="section-title">Por categoría</h2>
      </div>
      <div class="categories-grid">
        {categories.map(([key, cat]) => (
          <a href={`/categoria/${key}`} class={`cat-card cat-card--${key}`}>
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- YouTube CTA -->
  <section class="section yt-section">
    <div class="container yt-section__inner">
      <div class="eyebrow" style="justify-content:center">YouTube</div>
      <h2 class="section-title">También en YouTube</h2>
      <p>Tips de salud en 60 segundos. Shorts diarios con datos reales.</p>
      <a href="https://www.youtube.com/@VidaaSana360" target="_blank" rel="noopener" class="btn--warm btn btn--lg">
        Ver canal &rarr;
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-text { max-width: 760px; }
  .hero__title em { font-style: italic; color: var(--accent); }

  /* Per-category accent edge */
  .cat-card--nutricion     { box-shadow: inset 4px 0 0 #16A34A, var(--shadow-md); }
  .cat-card--ejercicio     { box-shadow: inset 4px 0 0 #F97316, var(--shadow-md); }
  .cat-card--mente         { box-shadow: inset 4px 0 0 #6366F1, var(--shadow-md); }
  .cat-card--longevidad    { box-shadow: inset 4px 0 0 #0891B2, var(--shadow-md); }
  .cat-card--recetas       { box-shadow: inset 4px 0 0 #DB2777, var(--shadow-md); }
  .cat-card--nutrition     { box-shadow: inset 4px 0 0 #16A34A, var(--shadow-md); }
  .cat-card--fitness       { box-shadow: inset 4px 0 0 #F97316, var(--shadow-md); }
  .cat-card--weight-loss   { box-shadow: inset 4px 0 0 #DB2777, var(--shadow-md); }
  .cat-card--wellness      { box-shadow: inset 4px 0 0 #0891B2, var(--shadow-md); }
  .cat-card--mental-health { box-shadow: inset 4px 0 0 #6366F1, var(--shadow-md); }

  .yt-section {
    text-align: center;
    background: var(--surface-1);
    border-top: 0.5px solid var(--line);
    border-bottom: 0.5px solid var(--line);
  }
  .yt-section__inner { max-width: 580px; margin: 0 auto; }
  .yt-section p {
    color: var(--ink-2);
    margin: 12px auto 24px;
    max-width: 520px;
    font-size: 16px;
  }

  @media (max-width: 600px) {
    .hero__actions { flex-direction: column; align-items: flex-start; }
    .hero__actions .btn-primary,
    .hero__actions .btn-ghost { width: 100%; justify-content: center; }
  }
</style>
